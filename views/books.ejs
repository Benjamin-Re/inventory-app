<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Books</title><link rel="stylesheet" type="text/css" href="/styles.css"></link>
</head>
<body>
    <%- include('navbar') %>
    <nav class="secondary-nav">
        <a href="/book/new">Add a Book</a>
        <a href="/book/deleteAll">Delete All Books</a>
    </nav>
    <main>
        <div class="secondary-container">
            <form id="sort-filter-form" method="GET" action="/book">
                
                <div>
                    <p>Sort by:</p>
                    <label><input type="radio" name="sort" value="price" <%= locals.sort === 'price' ? 'checked' : '' %>> price</label>
                    <label><input type="radio" name="sort" value="title" <%= locals.sort === 'title' ? 'checked' : '' %>> title</label>
                </div>
                <div>
                    <p>Filter by:</p>
                    <b>Category</b><br>
                    <% categories.forEach(category => { %>
                        <label><%= category.name %></label><input type="checkbox" name="filter" value="<%= category.id %>" 
                        <%= locals.filter && locals.filter.includes(String(category.id)) ? 'checked' : '' %> />
                    <% }) %>
                    <b>Author</b><br>
                    <% authors.forEach(author => { %>
                        <label><%= author.firstname %><%= author.lastname %></label><input type="checkbox" name="filterAuthor" value="<%= author.id %>" 
                        <%= locals.filterAuthor && locals.filterAuthor.includes(String(author.id)) ? 'checked' : '' %> />
                    <% }) %>
                </div>
            </form>
        </div>
        <div class="container">
        <% books.forEach(book => { %>
            <ul>
                <li><span>id:</span><%= book.id %></li>
                <li><span>title:</span> <%= book.title %>,</li>
                <li><span>price:</span> <%= book.price %>,</li>
                <li><span>author:</span> <%= book.firstname %>, <%= book.lastname %></li>
                <li><span>category:</span> <%= book.name %>,</li>
                <li><span>stock:</span> <%= book.stock %></li>
                <li><span>year:</span> <%= book.year %></li>
                <li><a href="/book/<%= book.id %>/update">Update</a></li>
                <li><a href="/book/<%= book.id %>/delete">Delete</a></li>
            </ul>
            <% }) %>
        </div>
    </main>
    <script>
        document.querySelectorAll('input[name="sort"]').forEach(radio => {
            radio.addEventListener('change', () => document.getElementById('sort-filter-form').submit());
        });
        document.querySelectorAll('input[name="filter"]').forEach(checkbox => {
            checkbox.addEventListener('change', () => document.getElementById('sort-filter-form').submit());
        });
        document.querySelectorAll('input[name="filterAuthor"]').forEach(checkbox => {
            checkbox.addEventListener('change', () => document.getElementById('sort-filter-form').submit());
        });
    </script>
</body>
</html>